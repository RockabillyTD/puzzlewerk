<?xml version="1.0" encoding="utf-8"?>
<!-- Regel S2: Ab Android 12 ersetzt dataExtractionRules das Attribut
     allowBackup. Backups und Geraete-Transfers bleiben vollstaendig
     deaktiviert, bis ein ADR etwas anderes festlegt. -->
<data-extraction-rules>
  <cloud-backup>
    <exclude domain="root" path="." />
  </cloud-backup>
  <device-transfer>
    <exclude domain="root" path="." />
  </device-transfer>
</data-extraction-rules>